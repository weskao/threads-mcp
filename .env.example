# Threads API Configuration
# Get your access token from: https://developers.facebook.com/docs/threads

THREADS_APP_ID=your_threads_app_id_here
THREADS_APP_SECRET=your_threads_app_secret_here
THREADS_ACCESS_TOKEN=your_threads_access_token_here

# Meta Developer console App ID and Business Manager ID — read from the browser URL bar.
# These are non-sensitive and stored in plaintext. Used only to customize doc links
# in SETUP.md and GET_THREADS_TOKEN.md. `npm run customize-docs` writes/updates them automatically.
# APP_ID=123456789
# BUSINESS_ID=987654321

# Optional: API Base URL (defaults to https://graph.threads.net/v1.0)
# THREADS_API_BASE_URL=https://graph.threads.net/v1.0

# Optional: Enable debug logging
# DEBUG=true

# Optional: Local image server port for publish_thread_local_image (default: 51847)
# LOCAL_IMAGE_SERVER_PORT=51847

# Optional: ngrok authtoken for publish_thread_local_image
# Alternative to `ngrok config add-authtoken` — set this if you prefer keychain management.
# ngrok reads NGROK_AUTHTOKEN automatically; no add-authtoken command needed when this is set.
# macOS (Keychain):
# NGROK_AUTHTOKEN=$(security find-generic-password -a "$USER" -s "ngrok-authtoken" -w 2>/dev/null)
# Windows (PasswordVault):
# NGROK_AUTHTOKEN=$(powershell -Command "try { ((New-Object Windows.Security.Credentials.PasswordVault).Retrieve('threads-mcp', 'ngrok-authtoken')).Password } catch { exit 1 }")
# Linux (Secret Service):
# NGROK_AUTHTOKEN=$(secret-tool lookup application threads-mcp service ngrok-authtoken 2>/dev/null)

# Optional: ngrok static domain for publish_thread_local_image
# ngrok free plan gives one static domain per account — it never changes.
# Free-plan domains always use the *.ngrok-free.dev suffix (find yours at
# https://dashboard.ngrok.com/domains after enabling the feature).
# Set it here so npm run ngrok-images always tunnels to the same URL.
# Both formats are accepted; the https:// prefix and trailing slash are
# stripped automatically before the domain is passed to ngrok --url.
#   Plain hostname:  NGROK_URL=your-static-domain.ngrok-free.dev
#   Full URL:        NGROK_URL=https://your-static-domain.ngrok-free.dev/
NGROK_URL=your-static-domain.ngrok-free.dev
